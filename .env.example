# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Supabase Connect URL
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"
DIRECT_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-super-secret-key-replace-me"
NEXTAUTH_URL="http://localhost:3000"


# Gemini API - get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
LANGLY_API_KEY=""

# S3 Bucket Setup (Configured for AWS or S3-compatible like Cloudflare R2 / MinIO)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""
AWS_S3_BUCKET_NAME=""
# Provide endpoint if using Cloudflare R2 (e.g., https://<ACCOUNT_ID>.r2.cloudflarestorage.com)
# AWS_S3_ENDPOINT=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email Authentication (SMTP)
EMAIL_SERVER="smtp://examplegmail.com:password@smtp.gmail.com:587"
EMAIL_FROM="example@gmail.com"
